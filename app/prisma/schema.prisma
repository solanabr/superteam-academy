// app/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // МЕНЯЕМ ПРОВАЙДЕР
  url      = env("DATABASE_URL")
}

// 1. Roles (Enum поддерживается в Postgres)
enum Role {
  USER
  ADMIN
}

enum CourseStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

// 2. User
model User {
  id            String    @id @default(cuid()) // БЫЛО: @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  
  walletAddress String?   @unique
  username      String?   @unique
  bio           String?   @db.Text // Text для длинных строк
  twitterHandle String?
  githubHandle  String?
  
  role          Role      @default(USER)
  
  xp            Int       @default(0)
  level         Int       @default(0)
  streak        Int       @default(0)
  lastLogin     DateTime  @default(now())
  lastLessonAt  DateTime?

  hasCompletedOnboarding Boolean @default(false)
  preferences            Json?   // JSON поддерживается в Postgres

  accounts      Account[]
  sessions      Session[]
  enrollments   UserEnrollment[]
  progress      LessonProgress[]
  achievements  UserAchievement[]
  xpHistory     XPHistory[]
  challenges    UserChallenge[]
  discussions   Discussion[]
  createdCourses Course[]
}

// 3. NextAuth Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 4. Courses (CMS)
model Course {
  id          String         @id @default(cuid())
  slug        String         @unique
  title       String
  description String         @db.Text
  difficulty  String         @default("Beginner")
  xpPerLesson Int            @default(50)
  imageUrl    String?
  
  status      CourseStatus   @default(DRAFT)
  reviewComment String?      @db.Text

  authorId    String?
  author      User?          @relation(fields: [authorId], references: [id])

  modules     CourseModule[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model CourseModule {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  order       Int
  
  lessons     Lesson[]
}

model Lesson {
  id          String       @id @default(cuid())
  moduleId    String
  module      CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title       String
  content     String       @db.Text
  initialCode String?      @db.Text
  order       Int
  isChallenge Boolean      @default(true)
  
  validationRules Json?
}

// 5. Progress & Gamification
model UserEnrollment {
  id            String   @id @default(cuid())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  courseId      String
  enrolledAt    DateTime @default(now())

  @@unique([userId, courseId])
}

model LessonProgress {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  courseId    String
  lessonIndex Int
  status      String
  codeSnippet String?  @db.Text
  completedAt DateTime?

  @@unique([userId, courseId, lessonIndex])
}

model XPHistory {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  amount      Int
  source      String
  description String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Achievement {
  id                String   @id @default(cuid())
  slug              String   @unique
  name              String
  description       String
  image             String
  xpReward          Int
  collectionAddress String?  @unique 
  
  users             UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  achievementId String
  earnedAt      DateTime    @default(now())
  mintAddress   String?

  @@unique([userId, achievementId])
}

model Challenge {
  id          String   @id @default(cuid())
  title       String
  description String
  xpReward    Int      @default(25)
  targetCount Int
  type        String
  period      String   @default("DAILY")
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  
  userChallenges UserChallenge[]
}

model UserChallenge {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeId  String
  challenge    Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  
  currentCount Int       @default(0)
  isCompleted  Boolean   @default(false)
  claimedAt    DateTime?
  dateKey      String    

  @@unique([userId, challengeId, dateKey])
}

model Discussion {
  id          String   @id @default(cuid())
  courseId    String
  lessonIndex Int
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  
  content     String   @db.Text
  createdAt   DateTime @default(now())

  parentId    String?
  parent      Discussion?  @relation("DiscussionReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies     Discussion[] @relation("DiscussionReplies")
}