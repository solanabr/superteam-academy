// app/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// Модель User (расширенная для NextAuth)
model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  // NextAuth поля
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  
  // Наши поля
  walletAddress String?   @unique
  
  // Профиль
  username      String?   @unique // Уникальный, чтобы не было дублей
  bio           String?
  
  // Соцсети (храним username для отображения)
  twitterHandle String?
  githubHandle  String?
  
  // Геймификация
  xp            Int       @default(0)
  level         Int       @default(0)
  streak        Int       @default(0)
  lastLogin     DateTime  @default(now())
  lastLessonAt  DateTime?

  // Связи
  accounts      Account[]
  sessions      Session[]
  enrollments   UserEnrollment[]
  progress      LessonProgress[]
  achievements  UserAchievement[]
  xpHistory     XPHistory[]
}


// NextAuth: Account (хранит связи с GitHub/Google)
model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// NextAuth: Session
model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Остальные модели без изменений
model UserEnrollment {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  user          User     @relation(fields: [userId], references: [id])
  userId        String   @db.ObjectId
  courseId      String
  enrolledAt    DateTime @default(now())

  @@unique([userId, courseId])
}

model LessonProgress {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  userId      String   @db.ObjectId
  courseId    String
  lessonIndex Int
  status      String
  codeSnippet String?
  completedAt DateTime?

  @@unique([userId, courseId, lessonIndex])
}

model Achievement {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  slug              String   @unique
  name              String
  description       String
  image             String
  xpReward          Int
  
  // НОВОЕ ПОЛЕ: Адрес коллекции (Mint) этого типа ачивки
  collectionAddress String?  @unique 
  
  users             UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  user          User        @relation(fields: [userId], references: [id])
  userId        String      @db.ObjectId
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  achievementId String      @db.ObjectId
  earnedAt      DateTime    @default(now())
  mintAddress   String?     // Адрес NFT в блокчейне (после минта)

  @@unique([userId, achievementId])
}

model XPHistory {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  userId      String   @db.ObjectId
  amount      Int
  source      String   // "lesson", "achievement", "bonus"
  description String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}