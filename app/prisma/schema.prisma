// app/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

// Модель User (расширенная для NextAuth)
model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  // NextAuth поля
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  
  // Наши поля
  walletAddress String?   @unique
  
  // Профиль
  username      String?   @unique // Уникальный, чтобы не было дублей
  bio           String?
  
  // Соцсети (храним username для отображения)
  twitterHandle String?
  githubHandle  String?

  role          Role      @default(USER)
  hasCompletedOnboarding Boolean @default(false)
  
  // Геймификация
  xp            Int       @default(0)
  level         Int       @default(0)
  streak        Int       @default(0)
  lastLogin     DateTime  @default(now())
  lastLessonAt  DateTime?

  // Связи
  accounts      Account[]
  sessions      Session[]
  enrollments   UserEnrollment[]
  progress      LessonProgress[]
  achievements  UserAchievement[]
  xpHistory     XPHistory[]
  challenges    UserChallenge[]
  discussions   Discussion[]
}


// NextAuth: Account (хранит связи с GitHub/Google)
model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// NextAuth: Session
model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Остальные модели без изменений
model UserEnrollment {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  user          User     @relation(fields: [userId], references: [id])
  userId        String   @db.ObjectId
  courseId      String
  enrolledAt    DateTime @default(now())

  @@unique([userId, courseId])
}

model LessonProgress {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  userId      String   @db.ObjectId
  courseId    String
  lessonIndex Int
  status      String
  codeSnippet String?
  completedAt DateTime?

  @@unique([userId, courseId, lessonIndex])
}

model Achievement {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  slug              String   @unique
  name              String
  description       String
  image             String
  xpReward          Int
  
  // НОВОЕ ПОЛЕ: Адрес коллекции (Mint) этого типа ачивки
  collectionAddress String?  @unique 
  
  users             UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  user          User        @relation(fields: [userId], references: [id])
  userId        String      @db.ObjectId
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  achievementId String      @db.ObjectId
  earnedAt      DateTime    @default(now())
  mintAddress   String?     // Адрес NFT в блокчейне (после минта)

  @@unique([userId, achievementId])
}

model XPHistory {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  userId      String   @db.ObjectId
  amount      Int
  source      String   // "lesson", "achievement", "bonus"
  description String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Course {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  slug        String         @unique // Идентификатор в блокчейне (solana-mock-test)
  title       String
  description String
  difficulty  String         @default("Beginner") // Beginner, Intermediate, Advanced
  xpPerLesson Int            @default(50)
  imageUrl    String?
  isPublished Boolean        @default(false)
  
  modules     CourseModule[] // Связь с модулями
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model CourseModule {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  courseId    String   @db.ObjectId
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  order       Int      // Порядок модуля (1, 2, 3...)
  
  lessons     Lesson[] // Связь с уроками
}

model Lesson {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  moduleId    String       @db.ObjectId
  module      CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title       String
  content     String       // Текст урока в формате Markdown
  initialCode String?      // Стартовый код (для практики)
  order       Int          // Глобальный индекс урока в курсе (0, 1, 2...) для блокчейна
  isChallenge Boolean      @default(true) // true = практика с кодом, false = только текст/видео
}

model Challenge {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String   // "Complete 3 lessons today"
  description String
  xpReward    Int      @default(25)
  targetCount Int      // Сколько действий нужно сделать (например, 3)
  type        String   // "LESSON_COUNT", "LOGIN_STREAK"
  isActive    Boolean  @default(true)
  
  userChallenges UserChallenge[]
}

model UserChallenge {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  userId       String    @db.ObjectId
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeId  String    @db.ObjectId
  challenge    Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  
  currentCount Int       @default(0) // Сколько уже сделал сегодня
  isCompleted  Boolean   @default(false)
  claimedAt    DateTime? // Время, когда забрал награду
  
  // Уникальный ключ: юзер + челендж + дата (строка YYYY-MM-DD)
  // Это позволит каждый день создавать новую запись
  dateKey      String    

  @@unique([userId, challengeId, dateKey])
}

model Discussion {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  courseId    String   // Привязка к курсу
  lessonIndex Int      // Привязка к конкретному уроку
  
  user        User     @relation(fields: [userId], references: [id])
  userId      String   @db.ObjectId
  
  content     String   // Текст вопроса/комментария
  createdAt   DateTime @default(now())
  
  // Ответы на этот комментарий (опционально для глубоких тредов, но мы сделаем плоские для начала)
  // upvotes    Int      @default(0)
}