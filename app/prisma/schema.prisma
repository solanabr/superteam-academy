// app/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// Модель User (расширенная для NextAuth)
model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  // NextAuth поля
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  
  // Наши поля
  walletAddress String?   @unique
  
  // Профиль
  username      String?   @unique // Уникальный, чтобы не было дублей
  bio           String?
  
  // Соцсети (храним username для отображения)
  twitterHandle String?
  githubHandle  String?
  
  // Геймификация
  xp            Int       @default(0)
  level         Int       @default(0)
  streak        Int       @default(0)
  lastLogin     DateTime  @default(now())
  lastLessonAt  DateTime?

  // Связи
  accounts      Account[]
  sessions      Session[]
  enrollments   UserEnrollment[]
  progress      LessonProgress[]
}


// NextAuth: Account (хранит связи с GitHub/Google)
model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// NextAuth: Session
model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Остальные модели без изменений
model UserEnrollment {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  user          User     @relation(fields: [userId], references: [id])
  userId        String   @db.ObjectId
  courseId      String
  enrolledAt    DateTime @default(now())

  @@unique([userId, courseId])
}

model LessonProgress {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  userId      String   @db.ObjectId
  courseId    String
  lessonIndex Int
  status      String
  codeSnippet String?
  completedAt DateTime?

  @@unique([userId, courseId, lessonIndex])
}