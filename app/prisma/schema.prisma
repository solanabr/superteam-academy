// app/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  walletAddress String   @unique
  username      String?
  bio           String?
  twitter       String?
  github        String?
  
  xp            Int      @default(0)
  level         Int      @default(0)
  streak        Int      @default(0)
  
  lastLogin     DateTime @default(now())
  lastLessonAt  DateTime? // Новое поле для честного расчета стриков

  // Связи
  enrollments   UserEnrollment[]
  progress      LessonProgress[]
}

// Новая модель для быстрого отображения списка курсов в Dashboard
model UserEnrollment {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  user          User     @relation(fields: [userId], references: [id])
  userId        String   @db.ObjectId
  courseId      String   // ID курса (anchor-101)
  enrolledAt    DateTime @default(now())

  @@unique([userId, courseId])
}

model LessonProgress {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  userId      String   @db.ObjectId // Связь с юзером
  courseId    String
  lessonIndex Int
  status      String   // "in_progress", "completed"
  codeSnippet String?
  completedAt DateTime?

  @@unique([userId, courseId, lessonIndex])
}