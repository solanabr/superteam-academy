# =============================================================================
# Superteam Academy — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- Prisma (connects to same Supabase PostgreSQL) ---
# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://postgres.your-project:your-password@aws-1-region.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://postgres.your-project:your-password@aws-1-region.pooler.supabase.com:5432/postgres"

# --- NextAuth ---
AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=same-as-AUTH_SECRET

# --- Google OAuth ---
# Get from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- GitHub OAuth ---
# Get from https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# --- App Config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Upstash Redis (nonce store, rate limiting, lockout) ---
# Get from https://console.upstash.com
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# --- Solana ---
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_PROGRAM_ID=ACADBRCB3zGvo1KSCbkztS33ZNzeBv2d7bqGceti3ucf
NEXT_PUBLIC_XP_MINT=xpXPUjkfk7t4AJF1tYUoyAYxzuM5DhinZWS1WjfjAu3
NEXT_PUBLIC_BACKEND_SIGNER=ACAd3USj2sMV6drKcMY2wZtNkhVDHWpC4tfJe93hgqYn

# Backend signer private key — obtain from repo maintainers
# Required for: complete_lesson, finalize_course, issue_credential, upgrade_credential
BACKEND_SIGNER_PRIVATE_KEY=

# --- Helius RPC (DAS API for credential NFTs, indexed asset queries) ---
# Get from https://dev.helius.xyz/dashboard
# Required for: credential lookups, user profile NFT display, getAsset/getAssetsByOwner
NEXT_PUBLIC_HELIUS_RPC_URL=
HELIUS_RPC_URL=

# --- Arweave Gateway ---
NEXT_PUBLIC_ARWEAVE_GATEWAY=https://arweave.net

# --- Code Execution (Self-hosted Judge0 CE on VPS) ---
# Deploy guide: docs/judge0-vps-setup.md
# Set CODE_EXECUTION_API_URL to your Judge0 VPS instance
# Set CODE_EXECUTION_AUTH_TOKEN to your AUTHN_TOKEN from judge0.conf
NEXT_PUBLIC_CODE_EXECUTION_ENABLED=false
CODE_EXECUTION_API_URL=
CODE_EXECUTION_AUTH_TOKEN=
CODE_EXECUTION_TIMEOUT_MS=10000
CODE_EXECUTION_MAX_CODE_SIZE=65536

# --- Sanity CMS ---
# Get from https://sanity.io/manage
# Required for: course content, lessons, modules, challenges, instructor data
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=
SANITY_PREVIEW_SECRET=

# --- i18nexus (translation management) ---
# Get from https://app.i18nexus.com → Project Settings → API Key
#
# IMPORTANT: i18nexus free plan has a 100-string limit. This project has ~380
# translation strings across 3 locales (en, es, pt-BR), which exceeds the free
# tier. As a result, i18nexus cannot be used as the primary translation source.
#
# How translations work:
#   1. LOCAL JSON files (context/i18n/messages/*.json) are the PRIMARY source
#      of truth for all translations. These files are always loaded first.
#   2. If I18NEXUS_API_KEY is set, the API is fetched and deep-merged ON TOP
#      of local JSON. This allows i18nexus to override specific keys if needed.
#   3. If the API key is missing or the fetch fails, local JSON is used as-is.
#
# To add/edit translations: edit the local JSON files directly.
# To use i18nexus as an overlay: set the key below and add strings via the
# i18nexus dashboard (up to 100 strings on the free plan).
I18NEXUS_API_KEY=

# --- Analytics ---
# Google Analytics 4 — get from https://analytics.google.com
NEXT_PUBLIC_GA_ID=
# PostHog — get from https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
# Sentry — get from https://sentry.io/settings/projects/
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- Admin Access (RBAC) ---
# Admins can be granted access in two ways:
#   1. Email — added to `admin_whitelist` DB table (preferred for production)
#   2. Wallet — listed below OR added to `admin_whitelist` DB table
#
# Email-login admins get full admin GUI access (/admin/*) but must ALSO
# connect the wallet below to sign on-chain course transactions (create/update).
#
# The Solana on-chain program enforces that only the config authority wallet
# (the wallet that initialized the program) can call create_course / update_course.
# This wallet MUST match one of the wallets listed here.
#
# Comma-separated for multiple wallets:
#   ADMIN_WALLETS=wallet1,wallet2
ADMIN_WALLETS=
# Set to 'true' in production to disable env-based admin fallback
# DISABLE_ENV_ADMIN=true

# --- Security ---
# Separate encryption key for callback URL tokens (falls back to AUTH_SECRET if unset)
CALLBACK_SECRET=change-me-in-production

# Optional: additional allowed origins for CSRF verification (comma-separated)
# Used for preview/staging deployments (e.g., Vercel preview URLs)
# ALLOWED_ORIGINS=https://yourapp-git-branch.vercel.app
