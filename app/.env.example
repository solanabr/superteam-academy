# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/superteam_academy?schema=public

# Authentication (Privy — wallet + Google + GitHub)
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Solana
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# S3 Media Storage (optional — falls back to local ./public/cms-media if not set)
# Works with AWS S3, Cloudflare R2, MinIO, DigitalOcean Spaces, etc.
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=  # Uncomment for S3-compatible providers (R2, MinIO, etc.)

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_CLARITY_PROJECT_ID=
NEXT_PUBLIC_SENTRY_DSN=

# Helius (for DAS API / ZK Compression)
NEXT_PUBLIC_HELIUS_API_KEY=

# Admin (comma-separated wallet public keys for /admin access control)
NEXT_PUBLIC_ADMIN_WALLETS=

# On-chain backend signer (base58 or JSON array of 64 bytes)
BACKEND_SIGNER_PRIVATE_KEY=

# Metaplex Core track collection addresses (one per track ID)
TRACK_COLLECTION_0=
TRACK_COLLECTION_1=
TRACK_COLLECTION_2=

# Payload CMS
PAYLOAD_SECRET=change-me-to-a-random-32-char-string
