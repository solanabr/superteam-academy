# Solana network: mainnet | mainnet-beta | devnet | testnet | localnet (default: devnet)
NEXT_PUBLIC_SOLANA_NETWORK=devnet
# Optional explicit RPC endpoint override (recommended to avoid accidental mainnet default)
# NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_ACADEMY_API_URL=http://localhost:3001

# PostHog (optional; omit to disable analytics)
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com  # or https://eu.i.posthog.com
