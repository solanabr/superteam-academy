# Public (client-side)
NEXT_PUBLIC_PROGRAM_ID=
NEXT_PUBLIC_XP_MINT=
NEXT_PUBLIC_BACKEND_SIGNER=
NEXT_PUBLIC_CLUSTER=devnet
NEXT_PUBLIC_SOLANA_RPC=

# Optional: app URL for API calls (default: same-origin)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Community (Postgres)
DATABASE_URL=

# -----------------------------------------------------------------------------
# Analytics (optional; omit to disable)
# -----------------------------------------------------------------------------
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Microsoft Clarity project ID (heatmaps; from clarity.microsoft.com)
# NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Sentry DSN (public; for client and optional server/edge)
# NEXT_PUBLIC_SENTRY_DSN=
# Sentry org/project for source map upload (CI only)
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=  

# BFF → Backend (server-only, not exposed to client)
# -----------------------------------------------------------------------------
# Backend base URL.
BACKEND_URL=http://localhost:3001

# API token for BFF to call backend. Must match backend BACKEND_API_TOKEN,
# or use a key from POST /v1/admin/generate-api-key (test page → Admin Auth).
BACKEND_API_TOKEN=

# JWT secret for verifying admin tokens on academy BFF. Must match backend ADMIN_SECRET
# (same value used to sign tokens from POST /v1/admin/login). Required for create-course,
# update-course, update-config, and other admin-only academy actions.
ADMIN_JWT_SECRET=
NEXT_PUBLIC_USE_SANITY=true

# Sanity (content + stubs). Project/dataset must match backend SANITY_* for Sync from Sanity.
# From sanity.io/manage → your project → API: Project ID and dataset name.
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# NEXT_PUBLIC_SANITY_DATASET=production
# NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
# Server-only: API token with create permission (Manage → API → Tokens). Do NOT put the token in any NEXT_PUBLIC_ variable.
# SANITY_API_TOKEN=

# DAS / Credentials (Helius)
# NEXT_PUBLIC_HELIUS_RPC=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
# Or server-only: HELIUS_API_KEY= (used for leaderboard + credentials if NEXT_PUBLIC_HELIUS_RPC not set)
# Comma-separated track collection addresses for credential NFTs
# NEXT_PUBLIC_CREDENTIAL_TRACK_COLLECTIONS=

# Optional: URI treated as placeholder (no image fetch) for credentials
# NEXT_PUBLIC_CREDENTIAL_PLACEHOLDER_URI=
