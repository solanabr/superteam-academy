# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Auth (NextAuth v5) ───────────────────────────────────────────────────────
AUTH_SECRET=""                        # Generate: openssl rand -base64 32
AUTH_URL="http://localhost:3000"

AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ─── Sanity CMS ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"
SANITY_API_TOKEN=""

# ─── Solana / On-Chain ────────────────────────────────────────────────────────
NEXT_PUBLIC_SOLANA_RPC_URL="https://api.devnet.solana.com"
NEXT_PUBLIC_SOLANA_NETWORK="devnet"                          # devnet | mainnet-beta

NEXT_PUBLIC_SOLANA_PROGRAM_ID=""      # Deployed Anchor program address
NEXT_PUBLIC_PROGRAM_ID=""             # Same as above (alias)

NEXT_PUBLIC_SOLANA_XP_MINT=""         # Token-2022 XP mint address
NEXT_PUBLIC_XP_MINT=""                # Same as above (alias)

NEXT_PUBLIC_HELIUS_RPC_URL=""         # Helius RPC with DAS API (for credentials/leaderboard)

# Backend signer — base58 private key of the authority keypair
# Used server-side only to sign lesson-complete and mint-credential transactions
BACKEND_SIGNER_KEYPAIR=""
ADMIN_SECRET_KEY=""                   # Same keypair (alias used by admin routes)

# Metaplex Core collection address for credential NFTs
CREDENTIAL_COLLECTION_ADDRESS=""

# ─── Monitoring ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

NEXT_PUBLIC_GA_ID=""                  # Google Analytics measurement ID (optional)

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="Superteam Academy <onboarding@resend.dev>"

# ─── Storage (Cloudflare R2) ──────────────────────────────────────────────────
# Used for admin video uploads via BunnyStream / tus-js-client
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# ─── Cache (Upstash Redis) ────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SERVER_URL="http://localhost:3000"
