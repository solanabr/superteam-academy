# Privy Auth (get your app ID from https://privy.io)
NEXT_PUBLIC_PRIVY_APP_ID=placeholder

# Solana RPC (Helius - get free API key from https://helius.xyz)
NEXT_PUBLIC_HELIUS_RPC=https://api.devnet.helius-rpc.com

# Gemini AI (get free API key from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=placeholder

# Sanity CMS (optional - for content management)
NEXT_PUBLIC_SANITY_PROJECT_ID=placeholder
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=placeholder

# Google Analytics (get measurement ID from https://analytics.google.com)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Microsoft Clarity (get project ID from https://clarity.microsoft.com)
NEXT_PUBLIC_CLARITY_ID=placeholder
