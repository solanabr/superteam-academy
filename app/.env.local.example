# ─── Solana / On-Chain ────────────────────────────────────────────────────────
# Use the same program ID in both frontend and backend (.env.example)
NEXT_PUBLIC_PROGRAM_ID=64XGGSc32TUX7rxge5u4Qsv55RQN5ybSwS4B1eksWTxy
NEXT_PUBLIC_CLUSTER=devnet
NEXT_PUBLIC_XP_MINT=
NEXT_PUBLIC_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
NEXT_PUBLIC_HELIUS_API_KEY=
NEXT_PUBLIC_HELIUS_RPC_URL=

# Track Collections (comma-separated Metaplex Core collection addresses)
# One address per learning track — deployed when you run scripts/setup-tracks.ts
# Leave blank to show all non-burnt NFT assets owned by the wallet (useful for dev)
NEXT_PUBLIC_TRACK_COLLECTIONS=
# Achievement collection addresses (same pattern)
NEXT_PUBLIC_ACHIEVEMENT_COLLECTIONS=

# ─── Backend Signing Service (server-side only — NEVER exposed to client) ─────
# JSON byte array of the backend signer keypair.
# Generate: solana-keygen new --outfile backend-keypair.json && cat backend-keypair.json
# This keypair must match the backend_signer registered in the on-chain Config account.
BACKEND_KEYPAIR=[1,2,3,...]

# Admin wallet addresses (comma-separated) that can access /admin
NEXT_PUBLIC_ADMIN_WALLETS=

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Sanity CMS ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=k9esrahg
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# ─── Auth (Clerk) ─────────────────────────────────────────────────────────────
# Create a Clerk app at https://clerk.com — Google and GitHub OAuth are configured there
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ─── Analytics (optional — app works without these) ───────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# Get DSN from https://sentry.io — create a Next.js project
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
