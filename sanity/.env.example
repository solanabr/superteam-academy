# Standalone Sanity Studio + CLI (this workspace only — `sanity dev`, `sanity deploy`).
# The embedded Studio in the Next.js app (/studio) does NOT read these; it uses
# NEXT_PUBLIC_SANITY_PROJECT_ID / NEXT_PUBLIC_SANITY_DATASET from apps/web/.env.local.
# (sanity.config.ts and sanity.cli.ts fall back to "placeholder"/"production" when unset.)
SANITY_STUDIO_PROJECT_ID=your-sanity-project-id
SANITY_STUDIO_DATASET=production
