{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "quiz"
    },
    "key": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "produces": {
      "type": "string",
      "enum": [
        "funded-wallet",
        "deployed-program"
      ]
    },
    "consumes": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "funded-wallet",
          "deployed-program"
        ]
      }
    },
    "questions": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "prompt": {
            "type": "string",
            "minLength": 1
          },
          "multiSelect": {
            "default": false,
            "type": "boolean"
          },
          "options": {
            "minItems": 2,
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "label": {
                  "type": "string",
                  "minLength": 1
                },
                "correct": {
                  "type": "boolean"
                },
                "feedback": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "id",
                "label",
                "correct"
              ]
            }
          },
          "explanation": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "id",
          "prompt",
          "options"
        ]
      }
    }
  },
  "required": [
    "type",
    "key",
    "questions"
  ]
}
