{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^quest-[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "lesson",
        "lesson_batch",
        "challenge",
        "login_streak",
        "module"
      ]
    },
    "icon": {
      "type": "string"
    },
    "xpReward": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5000
    },
    "targetValue": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "resetType": {
      "type": "string",
      "enum": [
        "daily",
        "multi_day"
      ]
    },
    "active": {
      "default": true,
      "type": "boolean"
    }
  },
  "required": [
    "id",
    "name",
    "type",
    "xpReward",
    "targetValue",
    "resetType"
  ]
}
