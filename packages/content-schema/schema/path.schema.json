{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^path-[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "tag": {
      "type": "string"
    },
    "order": {
      "default": 0,
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "difficulty": {
      "type": "string",
      "enum": [
        "beginner",
        "intermediate",
        "advanced"
      ]
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "courses": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^course-[a-z0-9]+(?:-[a-z0-9]+)*$"
      }
    }
  },
  "required": [
    "id",
    "slug",
    "title",
    "difficulty"
  ]
}
