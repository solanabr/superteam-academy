{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "slug": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "label": {
        "type": "string",
        "minLength": 1
      },
      "description": {
        "type": "string"
      }
    },
    "required": [
      "slug"
    ]
  }
}
