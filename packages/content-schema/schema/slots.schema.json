{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "version": {
      "type": "number",
      "const": 1
    },
    "slots": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "pattern": "^lesson-[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "additionalProperties": {
        "type": "integer",
        "minimum": 0,
        "maximum": 255
      }
    },
    "retired": {
      "default": [],
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 0,
        "maximum": 255
      }
    },
    "next": {
      "type": "integer",
      "minimum": 0,
      "maximum": 256
    }
  },
  "required": [
    "version",
    "slots",
    "next"
  ]
}
