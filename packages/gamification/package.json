{
	"name": "@superteam-academy/gamification",
	"version": "1.0.0",
	"private": true,
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		},
		"./streak-system": {
			"types": "./dist/streak-system.d.ts",
			"import": "./dist/streak-system.mjs",
			"require": "./dist/streak-system.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {},
	"devDependencies": {
		"@types/node": "catalog:",
		"tsup": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
