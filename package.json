{
  "name": "superteam-lms",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "typecheck": "turbo typecheck",
    "test:scripts": "./apps/web/node_modules/.bin/vitest run --config vitest.config.ts",
    "clean": "turbo clean",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tsx": "^4.21.0",
    "turbo": "^2.3.0"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "@noble/hashes": "^1.8.0",
      "vite": "6.4.3",
      "vitest": "^4.1.0",
      "ws@7": "7.5.11",
      "ws@8": "^8.21.0",
      "undici@7": "^7.28.0",
      "form-data": "^4.0.6",
      "protobufjs": "^7.6.1",
      "shell-quote": "^1.8.4",
      "lodash": "^4.18.0",
      "flatted": "^3.4.2",
      "fast-uri": "^3.1.2",
      "serialize-javascript": "^7.0.3",
      "minimatch@3": "3.1.4",
      "minimatch@9": "^9.0.7",
      "picomatch@2": "2.3.2",
      "picomatch@4": "^4.0.4"
    }
  },
  "packageManager": "pnpm@10.34.4+sha512.8768be55200ae3f2226b6527fcca2687e14bc4e5f12d7721a0f25da3df47915177058648db4177baf348120fa0ba2752d8d8d93f6beaf1fe64ae18da8de961af",
  "engines": {
    "node": ">=18"
  }
}
