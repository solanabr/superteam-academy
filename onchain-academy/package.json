{
  "name": "onchain-academy",
  "version": "0.1.0",
  "license": "MIT",
  "scripts": {
    "build:pinocchio": "cargo build-sbf --manifest-path programs/onchain-academy-pinocchio/Cargo.toml --tools-version v1.54",
    "build:pinocchio:fresh": "bash scripts/build-pinocchio-deploy.sh",
    "build:all": "pnpm build:pinocchio",
    "test:layout": "cargo test -p onchain-academy-pinocchio",
    "test:integration": "cargo test --manifest-path tests/differential/Cargo.toml",
    "cu:pinocchio": "bash scripts/select-program.sh && CU_BASELINE_OUT=tests/CU_BASELINE.pinocchio.md pnpm exec ts-mocha -p ./tsconfig.json -t 1000000 tests/cu-measurement.ts",
    "cu:compare": "pnpm cu:pinocchio && node scripts/cu-compare.mjs"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@metaplex-foundation/mpl-core": "^1.7.0",
    "@metaplex-foundation/umi": "^1.5.1",
    "@metaplex-foundation/umi-bundle-defaults": "^1.5.1",
    "@metaplex-foundation/umi-web3js-adapters": "^1.5.1",
    "@noble/hashes": "^1.3.1",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.98.0"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "anchor-litesvm": "^0.2.1",
    "chai": "^4.3.4",
    "litesvm": "0.3.3",
    "mocha": "^9.0.3",
    "prettier": "^2.6.2",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.7.3"
  }
}
