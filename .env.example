# CMS
SANITY_PROJECT_ID="your-project-id"
SANITY_DATASET="production"
SANITY_API_VERSION="2024-01-01"
SANITY_WEBHOOK_SECRET="your-sanity-webhook-secret"
SANITY_API_READ_TOKEN="your-sanity-read-token"
SANITY_API_WRITE_TOKEN="your-sanity-write-token"
ENABLE_SANITY_ONCHAIN_SYNC="false"
ARWEAVE_KEYFILE="/absolute/path/to/arweave-key.json"

# Analytics
GA4_MEASUREMENT_ID="G-XXXXXXXXXX"
SENTRY_DSN="https://..."

# Redis
REDIS_URL="redis://localhost:6379"

# API Keys
HELIUS_API_KEY="your-helius-api-key"
ALCHEMY_API_KEY="your-alchemy-api-key"

# Email
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
