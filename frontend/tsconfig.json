{
	"extends": "../tsconfig.json",
	"include": [
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
		".next/types/**/*.ts"
	],
	"exclude": [
		"node_modules"
	],
	"compilerOptions": {
		"baseUrl": ".",
		"jsx": "preserve",
		"lib": [
			"dom",
			"dom.iterable",
			"ES2022"
		],
		"plugins": [
			{
				"name": "next"
			}
		],
		"paths": {
			"@/*": [
				"./*"
			],
			"@/components/*": [
				"./components/*"
			],
			"@/lib/*": [
				"./lib/*"
			],
			"@/packages/*": [
				"../packages/*"
			]
		}
	}
}
